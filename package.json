{
  "name": "vidya-steam-bot",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node --import tsx/esm src/index.ts",
    "dev": "node --env-file=.env --import tsx/esm src/index.ts",
    "lint": "eslint src/ prisma.config.ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma generate && prisma migrate dev",
    "db:migrate:deploy": "prisma generate && prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@t3-oss/env-core": "^0.13.11",
    "dotenv": "^17.4.2",
    "steam-totp": "^2.1.2",
    "steam-tradeoffer-manager": "^2.13.0",
    "steam-user": "^5.3.0",
    "steamcommunity": "^3.50.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/steam-totp": "^2.1.2",
    "@types/steam-tradeoffer-manager": "^2.11.2",
    "@types/steam-user": "^5.1.1",
    "@types/steamcommunity": "^3.43.8",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
